[alias]
    stat = status
    incoming = !git remote update -p; git log ..@{u}
    in = incoming
    outgoing = log @{u}..
    out = outgoing

[push]
    autoSetupRemote = true

[mergetool]
    prompt = false
    keepBackup = false
    keepTemporaries = false

[merge]
    conflictstyle = zdiff3

[core]
    pager = "command -v delta >/dev/null 2>&1 && delta || less"

[interactive]
    diffFilter = "command -v delta >/dev/null 2>&1 && delta --color-only || cat"

[delta]
    navigate = true
    line-numbers = true
    side-by-side = true

[diff]
    colorMoved = default
