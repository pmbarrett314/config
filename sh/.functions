#!/bin/sh

if [ -z "${PERSONAL_CONFIG_DIR+x}" ]; then
	echo "PERSONAL_CONFIG_DIR is not set"
	return 1
fi

INCLUDE="$PERSONAL_CONFIG_DIR/sh/.include"
# shellcheck source=/dev/null
[ -f "$INCLUDE" ] && . "$INCLUDE"

if [ -f "$HOME/.functions.local.pre" ]; then
	include_once "$HOME/.functions.local.pre"
fi

nameterm() {
	printf "\033]0;%s\007" "$@"
}

run_base64() {
	OS=$(get_os)

	if [ "$OS" = "macos" ]; then
		eval "$(printf "%s" "$1" | base64 -D)"
	else
		eval "$(printf "%s" "$1" | base64 -d)"
	fi
}

cdir() {
	cd "$@" && dir .
}

# Notify when a long-running command finishes. Use: `sleep 10; alert`
# Picks the best available notifier — Linux notify-send, macOS terminal-notifier or osascript.
alert() {
	_alert_status=$?
	_alert_cmd=$(history | tail -n 1 | sed -e 's/^[[:space:]]*[0-9]\{1,\}[[:space:]]*//' -e 's/[;&|][[:space:]]*alert$//')
	if [ "$_alert_status" = 0 ]; then
		_alert_title="Done"
		_alert_icon="terminal"
	else
		_alert_title="Failed"
		_alert_icon="error"
	fi
	if command -v notify-send >/dev/null 2>&1; then
		notify-send --urgency=low -i "$_alert_icon" "$_alert_cmd"
	elif command -v terminal-notifier >/dev/null 2>&1; then
		terminal-notifier -message "$_alert_cmd" -title "$_alert_title" >/dev/null 2>&1
	elif command -v osascript >/dev/null 2>&1; then
		osascript -e 'on run argv
display notification (item 1 of argv) with title (item 2 of argv)
end run' "$_alert_cmd" "$_alert_title" >/dev/null 2>&1
	fi
	unset _alert_status _alert_cmd _alert_title _alert_icon
}

# Find subl if possible. Mac version as default because that's where I use it the most
_subl_bin() {
	if command -v subl >/dev/null 2>&1; then
		command -v subl
	elif [ -x "/Applications/Sublime Text.app/Contents/SharedSupport/bin/subl" ]; then
		printf '%s\n' "/Applications/Sublime Text.app/Contents/SharedSupport/bin/subl"
	else
		return 1
	fi
}

# st [path...] — open files/dirs in Sublime Text (current dir if no args).
st() {
	_st_bin=$(_subl_bin) || {
		echo "st: Sublime Text (subl) not found" >&2
		return 1
	}
	[ "$#" -eq 0 ] && set -- .
	"$_st_bin" "$@"
	unset _st_bin
}

# stt — open the current directory in Sublime Text.
stt() {
	st .
}

if [ -f "$HOME/.functions.local.post" ]; then
	include_once "$HOME/.functions.local.post"
fi
