#!/bin/sh

if [ -z "${PERSONAL_CONFIG_DIR+x}" ]; then
	echo "PERSONAL_CONFIG_DIR is not set"
	return 1
fi

INCLUDE="$PERSONAL_CONFIG_DIR/sh/.include"
# shellcheck source=/dev/null
[ -f "$INCLUDE" ] && . "$INCLUDE"

include_once "$HOME/.env.local.pre"

# Homebrew PATH — covers macOS Apple Silicon, macOS Intel, and Linuxbrew
# skip if the parent shell already did it
if [ -z "${HOMEBREW_PREFIX:-}" ]; then
	for brew_bin in /opt/homebrew/bin/brew /usr/local/bin/brew /home/linuxbrew/.linuxbrew/bin/brew; do
		if [ -x "$brew_bin" ]; then
			eval "$("$brew_bin" shellenv)"
			break
		fi
	done
	unset brew_bin
fi

# PATH additions — must happen before the command -v checks below, since
# tools installed via ubi (and cargo) live in these dirs.
prepend_path "$HOME/bin"
prepend_path "$HOME/.bin"
prepend_path "$HOME/.local/bin"
prepend_path "$HOME/.atuin/bin"
include "$HOME/.cargo/env"

export STARSHIP_CONFIG="$PERSONAL_CONFIG_DIR/starship/starship.toml"
export ATUIN_CONFIG_DIR="$PERSONAL_CONFIG_DIR/atuin"
export INPUTRC="$PERSONAL_CONFIG_DIR/readline/.inputrc"
export TEALDEER_CONFIG_DIR="$PERSONAL_CONFIG_DIR/tealdeer"
export LG_CONFIG_FILE="$PERSONAL_CONFIG_DIR/lazygit/config.yml"
export TERMINFO_DIRS="${TERMINFO_DIRS:+$TERMINFO_DIRS:}$HOME/.local/share/terminfo"

export EDITOR="vi"
export PAGER="less"
export VISUAL="vi"

command -v bat >/dev/null 2>&1 && export MANPAGER="sh -c 'col -bx | bat -l man -p'"

if command -v fd >/dev/null 2>&1; then
	export FZF_DEFAULT_COMMAND='fd --type f --hidden --exclude .git'
	export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
	export FZF_ALT_C_COMMAND='fd --type d --hidden --exclude .git'
fi

if command -v vim >/dev/null 2>&1; then
	export EDITOR="vim"
	export VISUAL="vim"
fi

if [ -n "${DISPLAY+x}" ]; then
	if command -v st >/dev/null 2>&1; then
		export VISUAL="st"
	elif command -v kate >/dev/null 2>&1; then
		export VISUAL="kate -b"
	elif command -v mate >/dev/null 2>&1; then
		export VISUAL="mate -w"
	fi
fi

include "$HOME/.secrets"

include_once "$HOME/.env.local.post"
