#!/bin/sh
# Cross-shell include helpers.
#
#   include                  — source $1 if it exists
#   include_once             — source $1 unless already loaded this session
#   include_with_locals      — source $1 and any ~/$(basename $1).local.{pre,post}
#   include_once_with_locals — dedup + locals
#   clear_load_vars          — reset the load list (forces re-includes mid-session)
#   get_os                   — print the OS family
#
# every overridable rc file sources ~/.<basename>.local.pre
# near its top and ~/.<basename>.local.post at its end
# Uses inlcude-once to avoid duplication even if a file is include_with_locals'd

# Pick the fastest dedup backend for the current shell.
if [ -n "${ZSH_VERSION:-}" ]; then
	typeset -gA _PMB_LOADED
	_pmb_is_loaded() { [ -n "${_PMB_LOADED[$1]-}" ]; }
	_pmb_mark()      { _PMB_LOADED[$1]=1; }
elif [ -n "${BASH_VERSION:-}" ] && [ "${BASH_VERSINFO[0]:-0}" -ge 4 ]; then
	declare -gA _PMB_LOADED
	_pmb_is_loaded() { [ -n "${_PMB_LOADED[$1]-}" ]; }
	_pmb_mark()      { _PMB_LOADED[$1]=1; }
else
	# POSIX sh, bash 3.x: colon-delimited string + case pattern.
	# Leading/trailing colons let us match ":$1:" unambiguously.
	_PMB_LOADED=":"
	_pmb_is_loaded() {
		case "$_PMB_LOADED" in
			*":$1:"*) return 0 ;;
		esac
		return 1
	}
	_pmb_mark() { _PMB_LOADED="${_PMB_LOADED}$1:"; }
fi

include() {
	# shellcheck source=/dev/null
	[ -f "$1" ] && . "$1"
}

include_once() {
	_pmb_is_loaded "$1" && return 0
	_pmb_mark "$1"
	include "$1"
}

include_with_locals() {
	_pmb_base="$HOME/$(basename "$1")"
	[ -f "${_pmb_base}.local.pre" ]  && include_once "${_pmb_base}.local.pre"
	include "$1"
	[ -f "${_pmb_base}.local.post" ] && include_once "${_pmb_base}.local.post"
	unset _pmb_base
}

include_once_with_locals() {
	_pmb_is_loaded "$1" && return 0
	_pmb_mark "$1"
	include_with_locals "$1"
}

clear_load_vars() {
	unset _PMB_LOADED
	if [ -n "$ZSH_VERSION" ]; then
		typeset -gA _PMB_LOADED
	elif [ -n "$BASH_VERSION" ] && [ "${BASH_VERSINFO[0]:-0}" -ge 4 ]; then
		declare -gA _PMB_LOADED
	else
		_PMB_LOADED=":"
	fi
}

# get_os — print the OS family
get_os() {
	case "$(uname -s)" in
		Darwin)       echo macos   ;;
		Linux)        echo linux   ;;
		*BSD)         echo bsd     ;;
		CYGWIN*)      echo cygwin  ;;
		MINGW*|MSYS*) echo msys    ;;
		SunOS)        echo solaris ;;
		*)            echo unknown ;;
	esac
}
