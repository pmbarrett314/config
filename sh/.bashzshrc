#!/bin/bash
# Interactive config shared by bash and zsh
# Sourced by bash/.bashrc and zsh/.zshrc.

if [ -z "${PERSONAL_CONFIG_DIR+x}" ]; then
	echo "PERSONAL_CONFIG_DIR is not set"
	return 1
fi

include_once "$HOME/.bashzshrc.local.pre"

if [ -n "$ZSH_VERSION" ]; then
	_sh=zsh
elif [ -n "$BASH_VERSION" ]; then
	_sh=bash
else
	_sh=""
fi

if [ -n "$_sh" ]; then
	# Tool integrations
	command -v mise   >/dev/null 2>&1 && eval "$(mise activate "$_sh")"
	# fzf needs to come before atuin so atuin gets ctrl+r.
	# fzf older than 0.48.0 doesn't have shell init
	if command -v fzf >/dev/null 2>&1; then
		_fzf_ver=$(fzf --version 2>/dev/null | awk '{print $1}')
		if [ -n "$_fzf_ver" ] &&
			[ "$(printf '0.48.0\n%s\n' "$_fzf_ver" | sort -V | head -n 1)" = "0.48.0" ]; then
			eval "$(fzf --"$_sh")"
		fi
		unset _fzf_ver
	fi
	command -v zoxide >/dev/null 2>&1 && eval "$(zoxide init "$_sh" --cmd cd)"
	command -v atuin  >/dev/null 2>&1 && eval "$(atuin init "$_sh" --disable-up-arrow)"
	command -v direnv >/dev/null 2>&1 && eval "$(direnv hook "$_sh")"
	command -v navi   >/dev/null 2>&1 && eval "$(navi widget "$_sh")"

	if command -v uv >/dev/null 2>&1; then
		uv() {
			unset -f uv
			eval "$(command uv generate-shell-completion "$_sh")"
			uv "$@"
		}
	fi
	if command -v uvx >/dev/null 2>&1; then
		uvx() {
			unset -f uvx
			eval "$(command uvx --generate-shell-completion "$_sh")"
			uvx "$@"
		}
	fi

	# iTerm2 shell integration if installed
	include "$HOME/.iterm2_shell_integration.$_sh"
fi


include_once "$HOME/.bashzshrc.local.post"
